{
  "version": 2,
  "functions": {
    "harbour-manager/public/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(index.css|index.js|particles.js)",
      "dest": "/harbour-manager/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/harbour-manager/public/index.php"
    }
  ]
}
