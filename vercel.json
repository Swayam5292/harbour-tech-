{
  "functions": {
    "index.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/index.php", "dest": "/index.php" },
    { "src": "/index.css", "dest": "/index.css" },
    { "src": "/index.js", "dest": "/index.js" },
    { "src": "/particles.js", "dest": "/particles.js" },
    { "src": "/login.html", "dest": "/login.html" },
    { "src": "/admin_dashboard.html", "dest": "/admin_dashboard.html" },
    { "src": "/(.*\\.svg)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/(.*\\.jpg)", "dest": "/$1" },
    { "src": "/", "dest": "/index.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
