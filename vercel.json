{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/(.*\\.css)", "dest": "/$1" },
    { "src": "/(.*\\.js)", "dest": "/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/(.*\\.png)", "dest": "/$1" },
    { "src": "/(.*\\.jpg)", "dest": "/$1" },
    { "src": "/(.*\\.svg)", "dest": "/$1" },
    { "src": "/(.*\\.ico)", "dest": "/$1" },
    { "src": "/(.*\\.woff2?)", "dest": "/$1" },
    { "src": "/(.*\\.bat)", "dest": "/$1" },
    { "src": "/index.php", "dest": "/api/index.php" },
    { "src": "/process.php", "dest": "/api/process.php" },
    { "src": "/", "dest": "/api/index.php" },
    { "src": "/((?!api/).*)", "dest": "/api/index.php" }
  ]
}
