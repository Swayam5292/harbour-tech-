{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "/(style.css|script.js|particles.js|login.html|login.css|login.js|admin_dashboard.html|favicon.ico|robots.txt)",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
