{
    "name": "harbour-tech/root",
    "description": "Root proxy for Laravel on Vercel",
    "require": {
        "php": ">=8.1",
        "laravel/framework": "^11.0",
        "laravel/tinker": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "harbour-manager/app/",
            "Database\\Factories\\": "harbour-manager/database/factories/",
            "Database\\Seeders\\": "harbour-manager/database/seeders/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
